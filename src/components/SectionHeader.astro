---
interface Props {
	label: string;
	heading: string;
}

const { label, heading } = Astro.props;

// Split heading on "." to add lime-colored dots back
const parts = heading.split('.');
---

<div class="mb-16 md:mb-24">
	<p class="text-lime font-bold text-sm tracking-[0.3em] uppercase mb-4">
		{label}
	</p>
	<h2 class="font-heading text-3xl sm:text-4xl md:text-5xl uppercase tracking-tight max-w-3xl leading-[1.05]">
		{parts.map((part, i) => (
			<>
				<Fragment set:html={part.trim()} />
				{i < parts.length - 1 && <span class="text-lime">.</span>}
				{i < parts.length - 1 && <br />}
			</>
		))}
	</h2>
</div>
