---
const navLinks = [
	{ label: 'Μεθοδολογία', href: '/methodologia' },
	{ label: 'Προγράμματα', href: '/programmata' },
	{ label: 'Κοινότητα', href: '/koinotita' },
	{ label: 'About', href: '/about' },
	{ label: 'Επικοινωνία', href: '/epikoinonia' },
];
---

<footer class="py-16 md:py-24">
	<div class="max-w-7xl mx-auto px-6 md:px-12">
		<div class="grid grid-cols-1 md:grid-cols-4 gap-12 md:gap-8">

			<!-- Brand -->
			<div>
				<a href="/">
					<img src="/logo-full.svg" alt="RESET GYM" class="h-10 md:h-12 w-auto" />
				</a>
				<p class="text-grey text-sm leading-relaxed max-w-xs mt-4">
					Fitness Evolution. Δομή, Επιστήμη, Κοινότητα — η καλύτερη εκδοχή σου σε περιμένει.
				</p>
			</div>

			<!-- Nav Links -->
			<div>
				<p class="font-heading text-sm uppercase tracking-[0.2em] mb-4 text-light">Σελίδες</p>
				<ul class="space-y-3 text-grey text-sm">
					{navLinks.map(link => (
						<li>
							<a href={link.href} class="hover:text-lime transition-colors duration-150">
								{link.label}
							</a>
						</li>
					))}
				</ul>
			</div>

			<!-- Contact -->
			<div>
				<p class="font-heading text-sm uppercase tracking-[0.2em] mb-4 text-light">Επικοινωνία</p>
				<ul class="space-y-3 text-grey text-sm">
					<li>
						<a href="mailto:resetgym325@gmail.com" class="hover:text-lime transition-colors duration-150">
							resetgym325@gmail.com
						</a>
					</li>
					<li>
						<a href="tel:+302130319729" class="hover:text-lime transition-colors duration-150">
							213 031 9729
						</a>
					</li>
				</ul>
			</div>

			<!-- Credit -->
			<div>
				<p class="font-heading text-sm uppercase tracking-[0.2em] mb-4 text-light">Studio</p>
				<a href="https://www.itdev.gr/" target="_blank" rel="noopener noreferrer" class="text-grey text-sm hover:text-lime transition-colors duration-150">ITDEV</a>
			</div>

		</div>

		<div class="border-t border-light/5 mt-16 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
			<p class="text-grey/50 text-xs tracking-wider uppercase">
				&copy; 2026 Reset Gym. All rights reserved.
			</p>
			<p class="text-grey text-xs tracking-wider">
				Powered by <a href="https://www.itdev.gr/" target="_blank" rel="noopener noreferrer" class="hover:text-grey/50 transition-colors duration-150">ITDEV</a>
			</p>
		</div>
	</div>
</footer>
