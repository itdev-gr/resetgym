---
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import { createSupabaseClient } from '../../../lib/supabase';

const supabase = createSupabaseClient(Astro.cookies);
const { id } = Astro.params;

// Fetch existing client
const { data: client, error: fetchError } = await supabase
  .from('clients')
  .select('*')
  .eq('id', id)
  .single();

if (fetchError || !client) {
  return Astro.redirect('/dashboard');
}

let error = '';
let formValues = {
  full_name: client.full_name || '',
  email: client.email || '',
  phone: client.phone || '',
  start_date: client.start_date || '',
  payment_status: client.payment_status || 'pending',
  package: client.package || '',
  end_date: client.end_date || '',
  notes: client.notes || '',
};

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const packages = fd.getAll('package') as string[];
  formValues = {
    full_name: fd.get('full_name') as string,
    email: fd.get('email') as string,
    phone: fd.get('phone') as string,
    start_date: fd.get('start_date') as string,
    payment_status: fd.get('payment_status') as string,
    package: packages.join(', '),
    end_date: fd.get('end_date') as string,
    notes: fd.get('notes') as string,
  };

  if (!formValues.full_name?.trim()) {
    error = 'Το ονοματεπώνυμο είναι υποχρεωτικό.';
  } else {
    const { error: dbError } = await supabase
      .from('clients')
      .update({
        full_name: formValues.full_name.trim(),
        email: formValues.email?.trim() || null,
        phone: formValues.phone?.trim() || null,
        start_date: formValues.start_date || null,
        payment_status: formValues.payment_status || 'pending',
        package: formValues.package?.trim() || null,
        end_date: formValues.end_date || null,
        notes: formValues.notes?.trim() || null,
      })
      .eq('id', id);

    if (dbError) {
      error = 'Σφάλμα αποθήκευσης. Δοκιμάστε ξανά.';
    } else {
      return Astro.redirect('/dashboard?success=updated');
    }
  }
}
---

<Layout title="Επεξεργασία Πελάτη — RESET GYM">

  <section class="pt-32 md:pt-40 pb-24 md:pb-32 min-h-screen">
    <div class="max-w-2xl mx-auto px-6 md:px-12">

      <div class="mb-12">
        <p class="text-lime font-bold text-sm tracking-[0.3em] uppercase mb-4">
          Admin
        </p>
        <h1 class="font-heading text-3xl sm:text-4xl md:text-5xl uppercase leading-[0.95] tracking-tight">
          Επεξεργασία Πελάτη<span class="text-lime">.</span>
        </h1>
      </div>

      {error && (
        <div class="mb-6 border border-red-500/30 bg-red-500/10 text-red-400 text-sm px-4 py-3">
          {error}
        </div>
      )}

      <form method="POST" class="space-y-6">

        <div>
          <label for="full_name" class="block text-sm font-bold tracking-wider uppercase text-grey mb-2">
            Ονοματεπώνυμο *
          </label>
          <input
            type="text"
            id="full_name"
            name="full_name"
            required
            value={formValues.full_name}
            class="w-full bg-transparent border border-light/10 text-light px-4 py-3 text-sm focus:border-lime focus:outline-none transition-colors duration-150"
            placeholder="Ονοματεπώνυμο πελάτη"
          />
        </div>

        <div>
          <label for="email" class="block text-sm font-bold tracking-wider uppercase text-grey mb-2">
            Email
          </label>
          <input
            type="email"
            id="email"
            name="email"
            value={formValues.email}
            class="w-full bg-transparent border border-light/10 text-light px-4 py-3 text-sm focus:border-lime focus:outline-none transition-colors duration-150"
            placeholder="email@example.com"
          />
        </div>

        <div>
          <label for="phone" class="block text-sm font-bold tracking-wider uppercase text-grey mb-2">
            Τηλέφωνο
          </label>
          <input
            type="tel"
            id="phone"
            name="phone"
            value={formValues.phone}
            class="w-full bg-transparent border border-light/10 text-light px-4 py-3 text-sm focus:border-lime focus:outline-none transition-colors duration-150"
            placeholder="69XXXXXXXX"
          />
        </div>

        <div>
          <label for="start_date" class="block text-sm font-bold tracking-wider uppercase text-grey mb-2">
            Ημερομηνία Έναρξης
          </label>
          <input
            type="date"
            id="start_date"
            name="start_date"
            value={formValues.start_date}
            class="w-full bg-transparent bg-dark border border-light/10 text-light px-4 py-3 text-sm focus:border-lime focus:outline-none transition-colors duration-150"
          />
        </div>

        <div>
          <label for="end_date" class="block text-sm font-bold tracking-wider uppercase text-grey mb-2">
            Ημερομηνία Λήξης
          </label>
          <input
            type="date"
            id="end_date"
            name="end_date"
            value={formValues.end_date}
            class="w-full bg-transparent bg-dark border border-light/10 text-light px-4 py-3 text-sm focus:border-lime focus:outline-none transition-colors duration-150"
          />
        </div>

        <div>
          <label for="payment_status" class="block text-sm font-bold tracking-wider uppercase text-grey mb-2">
            Κατάσταση Πληρωμής
          </label>
          <select
            id="payment_status"
            name="payment_status"
            class="w-full bg-dark border border-light/10 text-light px-4 py-3 text-sm focus:border-lime focus:outline-none transition-colors duration-150"
          >
            <option value="pending" selected={formValues.payment_status === 'pending'}>Εκκρεμεί</option>
            <option value="paid" selected={formValues.payment_status === 'paid'}>Πληρωμένο</option>
            <option value="overdue" selected={formValues.payment_status === 'overdue'}>Ληξιπρόθεσμο</option>
          </select>
        </div>

        <fieldset>
          <legend class="block text-sm font-bold tracking-wider uppercase text-grey mb-4">
            Πακέτο
          </legend>
          <div class="space-y-3">
            {['Personal Training', 'Functional', 'Pilates Reformer'].map((pkg) => (
              <label class="flex items-center gap-3 cursor-pointer group">
                <input
                  type="checkbox"
                  name="package"
                  value={pkg}
                  checked={formValues.package.split(', ').includes(pkg)}
                  class="w-4 h-4 accent-lime bg-dark border border-light/10"
                />
                <span class="text-sm text-grey group-hover:text-light transition-colors duration-150">{pkg}</span>
              </label>
            ))}
          </div>
        </fieldset>

        <div>
          <label for="notes" class="block text-sm font-bold tracking-wider uppercase text-grey mb-2">
            Σημειώσεις
          </label>
          <textarea
            id="notes"
            name="notes"
            rows="4"
            class="w-full bg-transparent border border-light/10 text-light px-4 py-3 text-sm focus:border-lime focus:outline-none transition-colors duration-150 resize-y"
            placeholder="Προσθέστε σημειώσεις για τον πελάτη..."
          >{formValues.notes}</textarea>
        </div>

        <div class="flex gap-4 pt-4">
          <button
            type="submit"
            class="bg-lime text-dark font-bold text-sm tracking-wider uppercase px-8 py-4 hover:bg-lime-hover transition-colors duration-150"
          >
            Ενημέρωση
          </button>
          <a
            href="/dashboard"
            class="border border-light/10 text-grey font-bold text-sm tracking-wider uppercase px-8 py-4 hover:border-lime hover:text-lime transition-colors duration-150 inline-flex items-center"
          >
            Ακύρωση
          </a>
        </div>

      </form>

    </div>
  </section>

</Layout>
