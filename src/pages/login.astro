---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import { createSupabaseClient } from '../lib/supabase';

const supabase = createSupabaseClient(Astro.cookies);

// If already logged in, redirect to dashboard
const { data: { user } } = await supabase.auth.getUser();
if (user) {
  return Astro.redirect('/dashboard');
}

let error = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const email = formData.get('email') as string;
  const password = formData.get('password') as string;

  const { error: authError } = await supabase.auth.signInWithPassword({
    email,
    password,
  });

  if (authError) {
    error = 'Λάθος email ή κωδικός.';
  } else {
    return Astro.redirect('/dashboard');
  }
}
---

<Layout title="Σύνδεση — RESET GYM">

  <section class="pt-32 md:pt-40 pb-24 md:pb-32 min-h-screen">
    <div class="max-w-md mx-auto px-6 md:px-12">

      <div class="text-center mb-12">
        <p class="text-lime font-bold text-sm tracking-[0.3em] uppercase mb-6">
          Admin
        </p>
        <h1 class="font-heading text-3xl sm:text-4xl md:text-5xl uppercase leading-[0.95] tracking-tight">
          Σύνδεση<span class="text-lime">.</span>
        </h1>
      </div>

      {error && (
        <div class="mb-6 border border-red-500/30 bg-red-500/10 text-red-400 text-sm px-4 py-3">
          {error}
        </div>
      )}

      <form method="POST" class="space-y-6">
        <div>
          <label for="email" class="block text-sm font-bold tracking-wider uppercase text-grey mb-2">
            Email
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full bg-transparent border border-light/10 text-light px-4 py-3 text-sm focus:border-lime focus:outline-none transition-colors duration-150"
            placeholder="Το email σου"
          />
        </div>
        <div>
          <label for="password" class="block text-sm font-bold tracking-wider uppercase text-grey mb-2">
            Κωδικός
          </label>
          <input
            type="password"
            id="password"
            name="password"
            required
            class="w-full bg-transparent border border-light/10 text-light px-4 py-3 text-sm focus:border-lime focus:outline-none transition-colors duration-150"
            placeholder="Ο κωδικός σου"
          />
        </div>
        <button
          type="submit"
          class="w-full bg-lime text-dark font-bold text-sm tracking-wider uppercase px-8 py-4 hover:bg-lime-hover transition-colors duration-150"
        >
          Είσοδος
        </button>
      </form>

    </div>
  </section>

</Layout>
