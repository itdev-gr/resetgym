---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Login - Asterion Safari">
  <main class="min-h-screen flex items-center justify-center bg-[#f8f9fa] px-4">
    <div class="bg-white rounded-2xl shadow-lg p-8 border border-gray-100 w-full max-w-md">
      <div class="flex justify-center mb-8">
        <a href="/">
          <img src="/logo.png" alt="Asterion Safari" class="h-16" />
        </a>
      </div>

      <h1 class="text-2xl font-bold text-gray-900 text-center mb-6">Sign In</h1>

      <div id="error-message" class="hidden bg-red-50 text-red-600 text-sm rounded-xl px-4 py-3 mb-4"></div>

      <form id="login-form">
        <input
          type="email"
          id="email"
          placeholder="Email address"
          required
          class="border border-gray-200 rounded-xl px-4 py-3 text-sm w-full mb-4 block focus:outline-none focus:ring-2 focus:ring-orange-400"
        />
        <input
          type="password"
          id="password"
          placeholder="Password"
          required
          class="border border-gray-200 rounded-xl px-4 py-3 text-sm w-full mb-6 block focus:outline-none focus:ring-2 focus:ring-orange-400"
        />
        <button
          type="submit"
          id="submit-btn"
          class="bg-orange-500 hover:bg-orange-600 text-white font-semibold w-full py-3 rounded-full transition-colors cursor-pointer"
        >
          Sign In
        </button>
      </form>
    </div>
  </main>
</Layout>

<script>
  import { signInWithEmailAndPassword, onAuthStateChanged } from "firebase/auth";
  import { auth } from "../lib/firebase";

  onAuthStateChanged(auth, (user) => {
    if (user) {
      window.location.href = "/dashboard";
    }
  });

  const form = document.getElementById("login-form") as HTMLFormElement;
  const errorEl = document.getElementById("error-message") as HTMLDivElement;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    errorEl.classList.add("hidden");
    submitBtn.disabled = true;
    submitBtn.textContent = "Signing in...";

    const email = (document.getElementById("email") as HTMLInputElement).value;
    const password = (document.getElementById("password") as HTMLInputElement).value;

    try {
      await signInWithEmailAndPassword(auth, email, password);
      window.location.href = "/dashboard";
    } catch (err: any) {
      errorEl.textContent = err.code === "auth/invalid-credential"
        ? "Invalid email or password."
        : "Something went wrong. Please try again.";
      errorEl.classList.remove("hidden");
      submitBtn.disabled = false;
      submitBtn.textContent = "Sign In";
    }
  });
</script>
