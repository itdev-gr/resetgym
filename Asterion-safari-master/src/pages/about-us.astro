---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Testimonials from '../components/Testimonials.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="About Us - Asterion Safari">
  <Header />
  <main class="overflow-x-hidden max-w-[100vw] flex flex-col">
    <!-- Section 1: Full width hero image (shorter on mobile so booking fits on first screen) -->
    <div class="w-full h-56 sm:h-72 lg:h-96 overflow-hidden order-1">
      <img
        src="https://asterionsafari.com/wp-content/uploads/2024/03/DJI_0918-scaled.jpg"
        alt="Asterion Safari"
        class="w-full h-full object-cover object-center"
      >
    </div>

    <!-- Section 2: Mission text (order-3 on mobile so booking shows first) -->
    <section class="bg-white py-10 sm:py-16 order-3 lg:order-2">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <p class="text-gray-400 uppercase tracking-widest text-sm mb-3">
          Learn a bit about who we are
        </p>
        <h2 class="text-3xl font-bold text-gray-900 mb-10">Our Mission</h2>

        <p class="text-gray-600 leading-relaxed mb-6">
          "Asterion Safari" is a business created by two brothers, founded in 2021
          with the aim of offering its customers a high level of services. It all
          started with our vision to be able to show you the beauties and special
          landscapes of our island, while exploring the Cretan customs and traditions.
        </p>

        <p class="text-gray-600 leading-relaxed">
          We started by organizing guided Quad Safari excursions in small groups with
          a choice of driver-guide in the language of your choice, choosing brand name
          vehicles, so that our customers can experience the adventure combining comfort
          and safety. Our well-trained staff will ensure you a unique experience that
          you will never forget. Crete is an earthly paradise with well-hidden treasures,
          which you can discover through our various types of excursions.
        </p>
      </div>
    </section>

    <!-- Section 3: Testimonials (order-4 on mobile) -->
    <div class="order-4 lg:order-3">
      <Testimonials />
    </div>

    <!-- Section 4: Booking widget — order-2 on mobile so it appears right after hero on first screen -->
    <section id="booking-widget" class="bg-gray-50/80 py-6 sm:py-10 pb-20 sm:pb-10 border-t border-gray-100 scroll-mt-24 w-full overflow-x-hidden order-2 lg:order-4">
      <div class="max-w-5xl mx-auto w-full px-3 sm:px-6 box-border">
        <div class="bg-white rounded-2xl shadow-[0_2px_8px_rgba(0,0,0,0.06)] border border-gray-100 relative w-full max-w-full box-border overflow-x-hidden">
          <div class="flex flex-col lg:grid lg:grid-cols-[1fr_2fr_1fr_auto] divide-y lg:divide-y-0 lg:divide-x divide-gray-200">
            <div class="py-2.5 sm:py-3 px-3 sm:p-5 flex items-center gap-2 sm:gap-3 cursor-pointer relative hover:bg-gray-50/50 transition-colors rounded-t-2xl lg:rounded-t-none lg:rounded-l-2xl min-w-0 shrink-0 min-h-[2.75rem] sm:min-h-[3.25rem]" id="dest-btn">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-gray-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
              </svg>
              <div class="min-w-0 flex-1 w-0">
                <p class="text-xs text-gray-500 mb-0.5">Destination</p>
                <p class="text-xs sm:text-sm font-semibold text-orange-500 break-words lg:truncate" id="dest-label">Piskopiano</p>
              </div>
              <!-- Destination dropdown -->
              <div id="dest-dropdown" class="hidden absolute top-full left-0 mt-1 bg-white border border-gray-200 rounded-xl shadow-lg z-50 w-64 py-2">
                <div class="dest-item flex items-center gap-3 px-4 py-2.5 hover:bg-gray-50 cursor-pointer text-sm text-gray-700"><svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>Malia</div>
                <div class="dest-item flex items-center gap-3 px-4 py-2.5 hover:bg-gray-50 cursor-pointer text-sm text-gray-700"><svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>Sissi</div>
                <div class="dest-item flex items-center gap-3 px-4 py-2.5 hover:bg-gray-50 cursor-pointer text-sm text-gray-700"><svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>Milatos</div>
                <div class="dest-item flex items-center gap-3 px-4 py-2.5 hover:bg-gray-50 cursor-pointer text-sm text-gray-700"><svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>Stalida</div>
                <div class="dest-item flex items-center gap-3 px-4 py-2.5 hover:bg-gray-50 cursor-pointer text-sm text-gray-700"><svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>Chersonissos</div>
                <div class="dest-item flex items-center gap-3 px-4 py-2.5 hover:bg-gray-50 cursor-pointer text-sm text-gray-700"><svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>Koutouloufari</div>
                <div class="dest-item flex items-center gap-3 px-4 py-2.5 hover:bg-gray-50 cursor-pointer text-sm text-gray-700"><svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>Piskopiano</div>
                <div class="dest-item flex items-center gap-3 px-4 py-2.5 hover:bg-gray-50 cursor-pointer text-sm text-gray-700"><svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>Anissaras</div>
                <div class="dest-item flex items-center gap-3 px-4 py-2.5 hover:bg-gray-50 cursor-pointer text-sm text-gray-700"><svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>Analipsi</div>
                <div class="dest-item flex items-center gap-3 px-4 py-2.5 hover:bg-gray-50 cursor-pointer text-sm text-gray-700"><svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>Gouves</div>
                <div class="dest-item flex items-center gap-3 px-4 py-2.5 hover:bg-gray-50 cursor-pointer text-sm text-gray-700"><svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>Kokkini Hani</div>
              </div>
            </div>

            <div class="py-2.5 sm:py-3 px-3 sm:p-5 flex items-center gap-2 sm:gap-3 cursor-pointer relative hover:bg-gray-50/50 transition-colors min-w-0 shrink-0 min-h-[2.75rem] sm:min-h-[3.25rem]" id="date-btn">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-gray-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/>
              </svg>
              <div class="min-w-0 flex-1 w-0">
                <p class="text-xs text-gray-500 mb-0.5">From - To</p>
                <p class="text-xs sm:text-sm font-semibold text-orange-500 break-all lg:break-normal lg:truncate" id="date-label">Select dates</p>
              </div>
              <!-- Calendar dropdown -->
              <div id="cal-dropdown" class="hidden absolute top-full left-0 mt-1 bg-white border border-gray-200 rounded-xl shadow-lg z-50 p-4 w-[min(100vw-2rem,580px)]">
                <div class="grid grid-cols-2 gap-6" id="calendar-container">
                  <!-- JS will render calendar here -->
                </div>
              </div>
            </div>

            <div class="py-2.5 sm:py-3 px-3 sm:p-5 flex items-center gap-2 sm:gap-3 cursor-pointer relative hover:bg-gray-50/50 transition-colors min-w-0 shrink-0 min-h-[2.75rem] sm:min-h-[3.25rem]" id="adv-btn">
              <div class="min-w-0 flex-1">
                <p class="text-xs text-gray-500 mb-0.5">Advance</p>
                <p class="text-xs sm:text-sm font-semibold text-orange-500">More ▼</p>
              </div>
              <!-- Advanced filters dropdown -->
              <div id="adv-dropdown" class="hidden absolute top-full left-0 mt-1 bg-white border border-gray-200 rounded-xl shadow-lg z-50 p-6 w-80">
                <p class="font-bold text-sm mb-4">Filter Price</p>
                <div class="flex justify-between text-xs text-orange-500 mb-1">
                  <span>€130</span><span>€160</span>
                </div>
                <input type="range" min="130" max="160" value="160" class="w-full accent-orange-500 mb-6">
                <p class="font-bold text-sm mb-3">Durations</p>
                <div class="flex gap-6">
                  <label class="flex items-center gap-2 text-sm text-gray-600 cursor-pointer">
                    <input type="checkbox" class="accent-orange-500"> 4 – 6 Hours
                  </label>
                  <label class="flex items-center gap-2 text-sm text-gray-600 cursor-pointer">
                    <input type="checkbox" class="accent-orange-500"> 6 - 8 Hours
                  </label>
                </div>
              </div>
            </div>

            <div class="py-2.5 sm:py-3 px-3 sm:p-3 flex items-center justify-center rounded-b-2xl lg:rounded-b-none lg:rounded-r-2xl shrink-0">
              <button type="button" class="bg-orange-500 hover:bg-orange-600 text-white font-semibold text-sm px-8 py-3.5 rounded-xl w-full lg:max-w-[140px] transition-colors shadow-sm">
                Search
              </button>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  // Toggle destination dropdown
  const destBtn = document.getElementById('dest-btn');
  const destDropdown = document.getElementById('dest-dropdown');
  const destLabel = document.getElementById('dest-label');
  destBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    destDropdown.classList.toggle('hidden');
    calDropdown.classList.add('hidden');
    advDropdown.classList.add('hidden');
  });
  document.querySelectorAll('.dest-item').forEach(item => {
    item.addEventListener('click', (e) => {
      const name = e.currentTarget.getAttribute('data-dest') || e.currentTarget.textContent.trim();
      destLabel.textContent = name;
      destDropdown.classList.add('hidden');
    });
  });

  // Toggle calendar
  const dateBtn = document.getElementById('date-btn');
  const calDropdown = document.getElementById('cal-dropdown');
  const dateLabel = document.getElementById('date-label');
  let startDate = null, endDate = null;
  let currentMonth = new Date().getMonth();
  let currentYear = new Date().getFullYear();

  function renderCalendar() {
    const container = document.getElementById('calendar-container');
    if (!container) return;
    container.innerHTML = '';
    for (let i = 0; i < 2; i++) {
      let m = (currentMonth + i) % 12;
      let y = currentYear + Math.floor((currentMonth + i) / 12);
      const monthNames = ['January','February','March','April','May','June','July','August','September','October','November','December'];
      const days = ['Mo','Tu','We','Th','Fr','Sa','Su'];
      const firstDay = new Date(y, m, 1).getDay();
      const offset = firstDay === 0 ? 6 : firstDay - 1;
      const daysInMonth = new Date(y, m + 1, 0).getDate();
      let html = `<div>
        <div class="flex justify-between items-center mb-3">
          ${i === 0 ? `<button type="button" data-cal="prev" class="text-gray-400 hover:text-gray-600 text-lg px-2">←</button>` : '<div></div>'}
          <span class="font-semibold text-sm">${monthNames[m]} ${y}</span>
          ${i === 1 ? `<button type="button" data-cal="next" class="text-gray-400 hover:text-gray-600 text-lg px-2">→</button>` : '<div></div>'}
        </div>
        <div class="grid grid-cols-7 gap-1 text-xs text-gray-400 mb-2">
          ${days.map(d => `<div class="text-center">${d}</div>`).join('')}
        </div>
        <div class="grid grid-cols-7 gap-1">`;
      html += '<div></div>'.repeat(offset);
      for (let d = 1; d <= daysInMonth; d++) {
        const dateStr = `${String(m+1).padStart(2,'0')}/${String(d).padStart(2,'0')}/${y}`;
        const isToday = d === new Date().getDate() && m === new Date().getMonth() && y === new Date().getFullYear();
        const isStart = startDate === dateStr;
        const isEnd = endDate === dateStr;
        html += `<div class="cal-day text-center text-xs py-1 rounded cursor-pointer hover:bg-orange-100 ${isStart || isEnd ? 'bg-orange-500 text-white rounded-full' : ''} ${isToday && !isStart && !isEnd ? 'border border-orange-400' : ''}" data-date="${dateStr}">${d}</div>`;
      }
      html += '</div></div>';
      container.innerHTML += html;
    }
  }

  // One-time delegation: calendar nav and day clicks (no new listeners on each render)
  document.getElementById('calendar-container')?.addEventListener('click', (e) => {
    e.stopPropagation();
    const prev = e.target.closest('[data-cal="prev"]');
    const next = e.target.closest('[data-cal="next"]');
    const day = e.target.closest('.cal-day');
    if (prev) { currentMonth--; if (currentMonth < 0) { currentMonth = 11; currentYear--; } renderCalendar(); return; }
    if (next) { currentMonth++; if (currentMonth > 11) { currentMonth = 0; currentYear++; } renderCalendar(); return; }
    if (day) {
      const d = day.dataset.date;
      if (!startDate || (startDate && endDate)) { startDate = d; endDate = null; }
      else { endDate = d; dateLabel.textContent = `${startDate} - ${endDate}`; }
      renderCalendar();
    }
  });

  dateBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    calDropdown.classList.toggle('hidden');
    destDropdown.classList.add('hidden');
    advDropdown.classList.add('hidden');
    renderCalendar();
  });

  // Toggle advanced filters
  const advBtn = document.getElementById('adv-btn');
  const advDropdown = document.getElementById('adv-dropdown');
  advBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    advDropdown.classList.toggle('hidden');
    destDropdown.classList.add('hidden');
    calDropdown.classList.add('hidden');
  });

  // Close all on outside click
  document.addEventListener('click', () => {
    destDropdown.classList.add('hidden');
    calDropdown.classList.add('hidden');
    advDropdown.classList.add('hidden');
  });
</script>
