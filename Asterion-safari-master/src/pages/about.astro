---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Testimonials from '../components/Testimonials.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="About Us - Asterion Safari">
  <Header />
  <main>
    <!-- Section 1: Full width hero image (no container, no padding) -->
    <div class="w-full h-96 overflow-hidden">
      <img
        src="https://asterionsafari.com/wp-content/uploads/2024/03/DJI_0918-scaled.jpg"
        alt="Asterion Safari"
        class="w-full h-full object-cover object-center"
      >
    </div>

    <!-- Section 2: Mission text + Google Maps, white bg, py-16 -->
    <section class="bg-white py-16">
      <div class="max-w-6xl mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 items-start">
          <!-- Left: Mission text -->
          <div>
            <p class="text-gray-400 uppercase tracking-widest text-sm mb-3">
              Learn a bit about who we are
            </p>
            <h2 class="text-3xl font-bold text-gray-900 mb-10">Our Mission</h2>

            <p class="text-gray-600 leading-relaxed mb-6">
              "Asterion Safari" is a business created by two brothers, founded in 2021
              with the aim of offering its customers a high level of services. It all
              started with our vision to be able to show you the beauties and special
              landscapes of our island, while exploring the Cretan customs and traditions.
            </p>

            <p class="text-gray-600 leading-relaxed">
              We started by organizing guided Quad Safari excursions in small groups with
              a choice of driver-guide in the language of your choice, choosing brand name
              vehicles, so that our customers can experience the adventure combining comfort
              and safety. Our well-trained staff will ensure you a unique experience that
              you will never forget. Crete is an earthly paradise with well-hidden treasures,
              which you can discover through our various types of excursions.
            </p>
          </div>

          <!-- Right: Google Maps (same height as left column) -->
          <div class="w-full min-h-[280px] h-full overflow-hidden rounded-xl border border-gray-200 shadow-sm">
            <iframe
              src="https://www.google.com/maps?cid=2663029144208670293&output=embed"
              width="100%"
              height="100%"
              style="border:0; display:block;"
              allowfullscreen=""
              loading="lazy"
              title="Asterion Safari location">
            </iframe>
          </div>
        </div>
      </div>
    </section>

    <!-- Section 3: Testimonials -->
    <Testimonials />

    <!-- Section 4: Booking widget -->
    <section class="bg-gray-50/80 py-10 border-t border-gray-100">
      <div class="max-w-7xl mx-auto px-8">
        <div class="bg-white rounded-2xl shadow-[0_2px_8px_rgba(0,0,0,0.06)] border border-gray-100 overflow-visible relative">
          <div class="grid grid-cols-[1fr_2fr_1fr_auto] divide-x divide-gray-200">
            <div class="p-5 flex items-center gap-3 cursor-pointer relative hover:bg-gray-50/50 transition-colors rounded-l-2xl" id="dest-btn">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-gray-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
              </svg>
              <div class="min-w-0 flex-1">
                <p class="text-xs text-gray-500 mb-0.5">Destination</p>
                <p class="text-sm font-semibold text-orange-500 truncate" id="dest-label">Piskopiano</p>
              </div>
              <div id="dest-dropdown" class="hidden absolute top-full left-0 mt-1 bg-white border border-gray-200 rounded-xl shadow-lg z-50 w-64 py-2">
                <div class="dest-item flex items-center gap-3 px-4 py-2.5 hover:bg-gray-50 cursor-pointer text-sm text-gray-700" data-dest="Malia"><svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>Malia</div>
                <div class="dest-item flex items-center gap-3 px-4 py-2.5 hover:bg-gray-50 cursor-pointer text-sm text-gray-700" data-dest="Sissi"><svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>Sissi</div>
                <div class="dest-item flex items-center gap-3 px-4 py-2.5 hover:bg-gray-50 cursor-pointer text-sm text-gray-700" data-dest="Milatos"><svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>Milatos</div>
                <div class="dest-item flex items-center gap-3 px-4 py-2.5 hover:bg-gray-50 cursor-pointer text-sm text-gray-700" data-dest="Stalida"><svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>Stalida</div>
                <div class="dest-item flex items-center gap-3 px-4 py-2.5 hover:bg-gray-50 cursor-pointer text-sm text-gray-700" data-dest="Chersonissos"><svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>Chersonissos</div>
                <div class="dest-item flex items-center gap-3 px-4 py-2.5 hover:bg-gray-50 cursor-pointer text-sm text-gray-700" data-dest="Koutouloufari"><svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>Koutouloufari</div>
                <div class="dest-item flex items-center gap-3 px-4 py-2.5 hover:bg-gray-50 cursor-pointer text-sm text-gray-700" data-dest="Piskopiano"><svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>Piskopiano</div>
                <div class="dest-item flex items-center gap-3 px-4 py-2.5 hover:bg-gray-50 cursor-pointer text-sm text-gray-700" data-dest="Anissaras"><svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>Anissaras</div>
                <div class="dest-item flex items-center gap-3 px-4 py-2.5 hover:bg-gray-50 cursor-pointer text-sm text-gray-700" data-dest="Analipsi"><svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>Analipsi</div>
                <div class="dest-item flex items-center gap-3 px-4 py-2.5 hover:bg-gray-50 cursor-pointer text-sm text-gray-700" data-dest="Gouves"><svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>Gouves</div>
                <div class="dest-item flex items-center gap-3 px-4 py-2.5 hover:bg-gray-50 cursor-pointer text-sm text-gray-700" data-dest="Kokkini Hani"><svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>Kokkini Hani</div>
              </div>
            </div>
            <div class="p-5 flex items-center gap-3 cursor-pointer relative hover:bg-gray-50/50 transition-colors" id="date-btn">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-gray-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/>
              </svg>
              <div class="min-w-0 flex-1">
                <p class="text-xs text-gray-500 mb-0.5">From - To</p>
                <p class="text-sm font-semibold text-orange-500 truncate" id="date-label">mm/dd/yyyy - mm/dd/yyyy</p>
              </div>
              <div id="cal-dropdown" class="hidden absolute top-full left-0 mt-1 bg-white border border-gray-200 rounded-xl shadow-lg z-50 p-4" style="width:580px">
                <div class="grid grid-cols-2 gap-6" id="calendar-container"></div>
              </div>
            </div>
            <div class="p-5 flex items-center gap-3 cursor-pointer relative hover:bg-gray-50/50 transition-colors" id="adv-btn">
              <div>
                <p class="text-xs text-gray-500 mb-0.5">Advance</p>
                <p class="text-sm font-semibold text-orange-500">More ▼</p>
              </div>
              <div id="adv-dropdown" class="hidden absolute top-full left-0 mt-1 bg-white border border-gray-200 rounded-xl shadow-lg z-50 p-6 w-80">
                <p class="font-bold text-sm mb-4">Filter Price</p>
                <div class="flex justify-between text-xs text-orange-500 mb-1"><span>€130</span><span>€160</span></div>
                <input type="range" min="130" max="160" value="160" class="w-full accent-orange-500 mb-6">
                <p class="font-bold text-sm mb-3">Durations</p>
                <div class="flex gap-6">
                  <label class="flex items-center gap-2 text-sm text-gray-600 cursor-pointer"><input type="checkbox" class="accent-orange-500"> 4 – 6 Hours</label>
                  <label class="flex items-center gap-2 text-sm text-gray-600 cursor-pointer"><input type="checkbox" class="accent-orange-500"> 6 - 8 Hours</label>
                </div>
              </div>
            </div>
            <div class="p-3 flex items-center justify-center rounded-r-2xl">
              <button type="button" class="bg-orange-500 hover:bg-orange-600 text-white font-semibold text-sm px-8 py-3.5 rounded-xl w-full max-w-[140px] transition-colors shadow-sm">Search</button>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  const destBtn = document.getElementById('dest-btn');
  const destDropdown = document.getElementById('dest-dropdown');
  const destLabel = document.getElementById('dest-label');
  destBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    destDropdown.classList.toggle('hidden');
    calDropdown.classList.add('hidden');
    advDropdown.classList.add('hidden');
  });
  document.querySelectorAll('.dest-item').forEach(item => {
    item.addEventListener('click', (e) => {
      destLabel.textContent = e.currentTarget.getAttribute('data-dest') || e.currentTarget.textContent.trim();
      destDropdown.classList.add('hidden');
    });
  });
  const dateBtn = document.getElementById('date-btn');
  const calDropdown = document.getElementById('cal-dropdown');
  const dateLabel = document.getElementById('date-label');
  let startDate = null, endDate = null;
  let currentMonth = new Date().getMonth();
  let currentYear = new Date().getFullYear();
  function renderCalendar() {
    const container = document.getElementById('calendar-container');
    if (!container) return;
    container.innerHTML = '';
    for (let i = 0; i < 2; i++) {
      let m = (currentMonth + i) % 12;
      let y = currentYear + Math.floor((currentMonth + i) / 12);
      const monthNames = ['January','February','March','April','May','June','July','August','September','October','November','December'];
      const days = ['Mo','Tu','We','Th','Fr','Sa','Su'];
      const firstDay = new Date(y, m, 1).getDay();
      const offset = firstDay === 0 ? 6 : firstDay - 1;
      const daysInMonth = new Date(y, m + 1, 0).getDate();
      let html = `<div><div class="flex justify-between items-center mb-3">${i === 0 ? `<button type="button" data-cal="prev" class="text-gray-400 hover:text-gray-600 text-lg px-2">←</button>` : '<div></div>'}<span class="font-semibold text-sm">${monthNames[m]} ${y}</span>${i === 1 ? `<button type="button" data-cal="next" class="text-gray-400 hover:text-gray-600 text-lg px-2">→</button>` : '<div></div>'}</div><div class="grid grid-cols-7 gap-1 text-xs text-gray-400 mb-2">${days.map(d => `<div class="text-center">${d}</div>`).join('')}</div><div class="grid grid-cols-7 gap-1">`;
      html += '<div></div>'.repeat(offset);
      for (let d = 1; d <= daysInMonth; d++) {
        const dateStr = `${String(m+1).padStart(2,'0')}/${String(d).padStart(2,'0')}/${y}`;
        const isStart = startDate === dateStr;
        const isEnd = endDate === dateStr;
        const isToday = d === new Date().getDate() && m === new Date().getMonth() && y === new Date().getFullYear();
        html += `<div class="cal-day text-center text-xs py-1 rounded cursor-pointer hover:bg-orange-100 ${isStart || isEnd ? 'bg-orange-500 text-white rounded-full' : ''} ${isToday && !isStart && !isEnd ? 'border border-orange-400' : ''}" data-date="${dateStr}">${d}</div>`;
      }
      html += '</div></div>';
      container.innerHTML += html;
    }
  }
  document.getElementById('calendar-container')?.addEventListener('click', (e) => {
    e.stopPropagation();
    if (e.target.closest('[data-cal="prev"]')) { currentMonth--; if (currentMonth < 0) { currentMonth = 11; currentYear--; } renderCalendar(); return; }
    if (e.target.closest('[data-cal="next"]')) { currentMonth++; if (currentMonth > 11) { currentMonth = 0; currentYear++; } renderCalendar(); return; }
    const day = e.target.closest('.cal-day');
    if (day) { const d = day.dataset.date; if (!startDate || (startDate && endDate)) { startDate = d; endDate = null; } else { endDate = d; dateLabel.textContent = `${startDate} - ${endDate}`; } renderCalendar(); }
  });
  dateBtn?.addEventListener('click', (e) => { e.stopPropagation(); calDropdown.classList.toggle('hidden'); destDropdown.classList.add('hidden'); advDropdown.classList.add('hidden'); renderCalendar(); });
  const advBtn = document.getElementById('adv-btn');
  const advDropdown = document.getElementById('adv-dropdown');
  advBtn?.addEventListener('click', (e) => { e.stopPropagation(); advDropdown.classList.toggle('hidden'); destDropdown.classList.add('hidden'); calDropdown.classList.add('hidden'); });
  document.addEventListener('click', () => { destDropdown.classList.add('hidden'); calDropdown.classList.add('hidden'); advDropdown.classList.add('hidden'); });
</script>
