---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact - Asterion Safari">
  <Header />
  <main>
    <!-- Section 1: Full width Google Map -->
    <iframe
      src="https://www.google.com/maps?cid=2663029144208670293&output=embed"
      width="100%"
      height="350"
      style="border:0; display:block;"
      allowfullscreen=""
      loading="lazy"
      title="Asterion Quads location map">
    </iframe>

    <!-- Section 2: Contact info + Send message -->
    <section class="bg-[#f8f9fa] py-16">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start max-w-6xl mx-auto px-6">
        <!-- Left column: Contact information -->
        <div class="pl-8 md:pl-12">
          <h2 class="text-2xl font-bold text-[#333] mb-2">Contact information</h2>
          <p class="text-gray-500 mb-8">Get in touch with us to secure your adventure today!</p>

          <div class="flex items-center gap-4 py-4 border-b border-gray-200">
            <div class="w-10 h-10 rounded-full bg-gray-100 flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-black" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <span class="text-gray-700">Machis Kritis 2, Malia, Crete, Greece</span>
          </div>
          <div class="flex items-center gap-4 py-4 border-b border-gray-200">
            <div class="w-10 h-10 rounded-full bg-gray-100 flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-black" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <a href="tel:+306976339969" class="text-gray-700 hover:text-orange-500 transition-colors">+(030) 6976339969 ( Viber, Whatsapp )</a>
          </div>
          <div class="flex items-center gap-4 py-4 border-b border-gray-200">
            <div class="w-10 h-10 rounded-full bg-gray-100 flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-black" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <a href="mailto:asterionquads@gmail.com" class="text-gray-700 hover:text-orange-500 transition-colors">asterionquads@gmail.com</a>
          </div>
        </div>

        <!-- Right column: Send a message card -->
        <div class="bg-white rounded-2xl shadow-lg p-8 border border-gray-100 self-start">
          <h3 class="text-xl font-bold mb-6 text-gray-900">Send a message</h3>

          <div class="grid grid-cols-2 gap-4 mb-4">
            <input
              type="text"
              placeholder="Your name*"
              class="border border-gray-200 rounded-xl px-4 py-3 text-sm w-full focus:outline-none focus:ring-2 focus:ring-orange-400"
            >
            <input
              type="text"
              placeholder="Phone number"
              class="border border-gray-200 rounded-xl px-4 py-3 text-sm w-full focus:outline-none focus:ring-2 focus:ring-orange-400"
            >
          </div>

          <input
            type="email"
            placeholder="Your email*"
            class="border border-gray-200 rounded-xl px-4 py-3 text-sm w-full mb-4 block focus:outline-none focus:ring-2 focus:ring-orange-400"
          >

          <textarea
            placeholder="Message"
            rows="6"
            class="border border-gray-200 rounded-xl px-4 py-3 text-sm w-full mb-6 block resize-y focus:outline-none focus:ring-2 focus:ring-orange-400"
          ></textarea>

          <button class="bg-orange-500 hover:bg-orange-600 text-white font-semibold px-8 py-3 rounded-full transition-colors cursor-pointer">
            Submit →
          </button>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
