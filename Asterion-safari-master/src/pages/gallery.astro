---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const galleryImages = Array.from({ length: 24 }, (_, i) => `/photo/gallery${i + 1}.webp`);

// Uniform grid (Exo Santorini style): all tiles same size, no span
const galleryItemClass =
  'gallery-item overflow-hidden rounded-lg shadow-sm cursor-pointer bg-gray-100 transition-all duration-300 hover:scale-[1.02] hover:shadow-md';
---

<Layout title="Gallery - Asterion Safari">
  <Header />
  <main class="pt-6 sm:pt-8">
    <div class="border-b border-gray-200"></div>
    <div class="max-w-6xl mx-auto px-6 py-3">
      <p class="text-sm text-gray-500">Home &gt; Gallery</p>
    </div>

    <section class="max-w-6xl mx-auto px-6 py-10">
      <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 text-center mb-10">Gallery</h1>

      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3 sm:gap-4 auto-rows-[180px] sm:auto-rows-[200px] md:auto-rows-[220px]">
        {galleryImages.map((src, i) => (
          <div
            class={galleryItemClass}
            style={`animation-delay: ${i * 40}ms`}
            data-index={i}
            role="button"
            tabindex={0}
            aria-label={`View image ${i + 1}`}
          >
            <img
              src={src}
              alt={`Gallery ${i + 1}`}
              class="w-full h-full object-cover min-h-full"
              loading="lazy"
              data-gallery-index={i}
            />
          </div>
        ))}
      </div>
    </section>
  </main>

  <!-- Lightbox -->
  <div
    id="lightbox"
    class="lightbox-backdrop fixed inset-0 z-50 hidden items-center justify-center p-6 sm:p-8"
    aria-hidden="true"
    role="dialog"
    aria-modal="true"
    aria-label="Image viewer"
  >
    <button
      type="button"
      id="lightbox-close"
      class="lightbox-close-btn lightbox-btn absolute z-[100] w-10 h-10 rounded-full bg-white/20 text-white hover:bg-white/30 flex items-center justify-center transition-colors"
      aria-label="Close"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
    <button
      type="button"
      id="lightbox-prev"
      class="lightbox-btn absolute left-2 sm:left-4 top-1/2 -translate-y-1/2 z-[100] w-12 h-12 rounded-full bg-white/20 text-white hover:bg-white/30 flex items-center justify-center transition-colors"
      aria-label="Previous image"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
    </button>
    <div class="lightbox-image-wrap relative z-10 flex items-center justify-center p-4">
      <img
        id="lightbox-img"
        src=""
        alt=""
        class="lightbox-img lightbox-image rounded-xl shadow-2xl opacity-0 transition-opacity duration-200"
      />
    </div>
    <button
      type="button"
      id="lightbox-next"
      class="lightbox-btn absolute right-2 sm:right-4 top-1/2 -translate-y-1/2 z-[100] w-12 h-12 rounded-full bg-white/20 text-white hover:bg-white/30 flex items-center justify-center transition-colors"
      aria-label="Next image"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
    </button>
  </div>

  <Footer />
</Layout>

<style>
  .gallery-item {
    opacity: 0;
    transform: scale(0.95);
    animation: galleryFadeIn 0.5s ease forwards;
  }
  .gallery-item img {
    pointer-events: none;
  }
  @keyframes galleryFadeIn {
    to {
      opacity: 1;
      transform: scale(1);
    }
  }
  #lightbox.flex {
    display: flex !important;
  }
  .lightbox-backdrop {
    transition: opacity 0.3s ease;
    background: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
  #lightbox:not(.lightbox-open) {
    opacity: 0;
  }
  #lightbox.lightbox-open {
    opacity: 1;
  }
  .lightbox-btn {
    pointer-events: auto;
  }
  #lightbox-close.lightbox-close-btn {
    top: 1rem;
    right: 1rem;
    left: auto;
    bottom: auto;
    transform: none;
  }
  #lightbox-prev,
  #lightbox-next {
    visibility: visible;
    opacity: 1;
    flex-shrink: 0;
  }
  #lightbox-next {
    right: 1rem;
  }
  @media (min-width: 640px) {
    #lightbox-next {
      right: 2rem;
    }
  }
  .lightbox-image {
    transition: transform 0.3s ease-out, opacity 0.3s ease-out;
  }
  #lightbox:not(.lightbox-open) .lightbox-image {
    transform: scale(0.9);
    opacity: 0;
  }
  #lightbox.lightbox-open .lightbox-image {
    transform: scale(1);
    opacity: 0;
  }
  #lightbox.lightbox-open .lightbox-image.loaded {
    opacity: 1;
  }
  .lightbox-image-wrap {
    min-height: 0;
    box-sizing: border-box;
    max-width: calc(100% - 8rem);
  }
  /* Lightbox img: explicit sizing so it never inherits grid/global img styles – full image visible, no crop */
  #lightbox .lightbox-img {
    width: auto !important;
    height: auto !important;
    max-width: 90vw !important;
    max-height: 90vh !important;
    object-fit: contain !important;
    display: block;
  }
</style>

<script define:vars={{ galleryImages }}>
  const LEN = galleryImages.length;
  let currentIndex = 0;

  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img');
  const lightboxClose = document.getElementById('lightbox-close');
  const lightboxPrev = document.getElementById('lightbox-prev');
  const lightboxNext = document.getElementById('lightbox-next');

  const LIGHTBOX_DURATION_MS = 300;

  function setImageAndShow(index) {
    if (!lightboxImg) return;
    lightboxImg.classList.remove('loaded');
    lightboxImg.src = galleryImages[index];
    lightboxImg.alt = `Gallery ${index + 1}`;
    lightboxImg.onload = () => lightboxImg.classList.add('loaded');
    if (lightboxImg.complete) lightboxImg.classList.add('loaded');
  }

  function openLightbox(index) {
    currentIndex = ((index % LEN) + LEN) % LEN;
    if (lightboxImg) setImageAndShow(currentIndex);
    if (lightbox) {
      lightbox.classList.remove('hidden');
      lightbox.classList.add('flex');
      lightbox.classList.remove('lightbox-open');
      document.body.style.overflow = 'hidden';
      requestAnimationFrame(() => {
        requestAnimationFrame(() => lightbox.classList.add('lightbox-open'));
      });
    }
  }

  function closeLightbox() {
    if (!lightbox) return;
    lightbox.classList.remove('lightbox-open');
    setTimeout(() => {
      lightbox.classList.add('hidden');
      lightbox.classList.remove('flex');
      document.body.style.overflow = '';
    }, LIGHTBOX_DURATION_MS);
  }

  function showPrev() {
    currentIndex = (currentIndex - 1 + LEN) % LEN;
    setImageAndShow(currentIndex);
  }

  function showNext() {
    currentIndex = (currentIndex + 1) % LEN;
    setImageAndShow(currentIndex);
  }

  document.querySelectorAll('.gallery-item').forEach((el) => {
    el.addEventListener('click', () => openLightbox(parseInt(el.dataset.index, 10)));
    el.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        openLightbox(parseInt(el.dataset.index, 10));
      }
    });
  });

  if (lightboxClose) lightboxClose.addEventListener('click', closeLightbox);
  if (lightbox) lightbox.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });
  if (lightboxPrev) lightboxPrev.addEventListener('click', (e) => { e.stopPropagation(); showPrev(); });
  if (lightboxNext) lightboxNext.addEventListener('click', (e) => { e.stopPropagation(); showNext(); });

  document.addEventListener('keydown', (e) => {
    if (!lightbox || !lightbox.classList.contains('flex')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') showPrev();
    if (e.key === 'ArrowRight') showNext();
  });
</script>
